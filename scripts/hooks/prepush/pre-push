#!/bin/sh
# подключение соседних файлов с функциями
. "$(dirname "$0")/utils"
. "$(dirname "$0")/detekt-check"

CI="${CI:-""}"

if [ "$CI" = "true" ]; then
  echo "CI is true, exiting..."
  exit 0
fi

echo "CI is not true, continue..."

status=0  # 0 = всё ок, 1 = есть ошибки
check_local_prop_flag "prepush.abortOnError" # проверяем флаг для выбора режима работы из local.properties
isAbortOnError=$? # устанавливаем значение флага isAbortOnError из результата выполнения предыдущей функции
if [ $isAbortOnError -eq 0 ]; then # проверка режима работы
    echo " ⚠️ Включен режим прекращения работы при ошибке (prepush.abortOnError = true)"
else
    echo " ⚠️ Включен режим продолжения работы при ошибке (prepush.abortOnError = false)"
fi

# Функция для выполнения проверок. В случае, если результат проверки не равен 0, то выставит значение status в 1
run_check() {
    local check_name=$1                                     # имя функции
    shift                                                   # убираем первый аргумент, чтобы остальные можно было передать в функцию
    if ! "$check_name" "$@"; then                           # если проверка не вернула 0
        if [ $isAbortOnError -eq 0 ]; then                  # если включен режим работы с прекращением при ошибке
            echo " ❌ Pre-push завершился с ошибками"       # показываем сообщение об ошибке
            exit 1                                          # завершаем работу скрипта с ошибкой
        else                                                # иначе
            status=1                                        # выставляем status в 1
        fi                                                  # конец fi
    fi                                                      # конец fi
}

#***********************************************
#                   Проверки
#***********************************************

# Запуск проверки Detekt
run_check detekt_check

#***********************************************
#                 Конец проверок
#***********************************************

# Если статус не равен 0, то выходим с ошибкой
if [ $status -ne 0 ]; then
    echo "❌ Pre-push завершился с ошибками"
    exit 1
fi